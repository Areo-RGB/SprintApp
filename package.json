{
  "name": "sprint-sync-monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "workspaces": [
    "windows/ui",
    "windows/desktop-tauri"
  ],
  "scripts": {
    "build:debug:apk": "cmd.exe /c \"cd /d android && gradlew.bat :app:assembleDebug\"",
    "build:release:apk": "cmd.exe /c \"cd /d android && gradlew.bat :app:assembleRelease\"",
    "rebuild:debug:devices": "npm run build:debug:apk && node scripts/install-debug-apk.mjs",
    "install:debug:devices:adb": "node scripts/install-debug-devices-adb.mjs",
    "rebuild:debug:devices:adb": "npm run build:debug:apk && npm run install:debug:devices:adb",
    "build:debug:device-flavors": "npm run build:debug:apk",
    "install:debug:device-flavors:adb": "npm run install:debug:devices:adb",
    "rebuild:debug:device-flavors:adb": "npm run rebuild:debug:devices:adb",
    "install:release:devices": "node scripts/install-release-apk.mjs",
    "rebuild:release:devices": "npm run build:release:apk && node scripts/install-release-apk.mjs",
    "install:release:devices:adb": "node scripts/install-release-devices-adb.mjs",
    "rebuild:release:devices:adb": "npm run build:release:apk && npm run install:release:devices:adb",
    "install:debug:devices:build": "npm run rebuild:debug:devices",
    "android:build:install:start": "npm run rebuild:debug:devices:adb",
    "windows:install": "npm install --workspaces --include-workspace-root",
    "windows:dev": "npm run dev --workspace @sprint-sync/windows-desktop-tauri",
    "windows:dev:desktop": "npm run windows:dev",
    "windows:start:all": "npm run windows:dev",
    "windows:dev:backend": "npm run windows:dev:desktop",
    "windows:dev:ui": "npm run dev --workspace @sprint-sync/windows-ui",
    "windows:build": "npm run build --workspace @sprint-sync/windows-ui && npm run build --workspace @sprint-sync/windows-desktop-tauri",
    "windows:start": "npm run windows:dev",
    "windows:start:exe": "cmd.exe /c start \"\" \"%cd%\\windows\\desktop-tauri\\src-tauri\\target\\release\\sprint-sync-windows-desktop-tauri.exe\"",
    "windows:kill:port:9000": "node scripts/windows-kill-port-9000.mjs",
    "windows:preview:ui": "npm run preview --workspace @sprint-sync/windows-ui",
    "windows:package:backend": "npm run windows:package:desktop",
    "windows:package:backend:exe": "npm run windows:package:desktop",
    "windows:package:desktop": "npm run windows:kill:port:9000 && npm run build --workspace @sprint-sync/windows-desktop-tauri && npm run windows:start:exe",
    "windows:package:desktop:build-tools": "cmd.exe /c \"\\\"C:\\Program Files\\Microsoft Visual Studio\\2022\\BuildTools\\VC\\Auxiliary\\Build\\vcvars64.bat\\\" && npm run windows:package:desktop\"",
    "windows:package:exe": "npm run windows:package:desktop",
    "windows:package:start:exe": "npm run windows:package:desktop",
    "run:android-and-exe": "npm run rebuild:debug:devices:adb && npm run windows:package:start:exe",
    "release:android": "node scripts/release-android.mjs",
    "release:windows": "node scripts/release-windows.mjs"
  },
  "devDependencies": {}
}
