{
  "name": "@sprint-sync/windows-desktop-tauri",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "prepare:runtime": "node scripts/prepare-runtime.mjs",
    "build": "npm run prepare:runtime && tauri build",
    "dev": "npm run prepare:runtime && tauri dev",
    "test": "npm run prepare:runtime && cargo test --manifest-path src-tauri/Cargo.toml",
    "smoke:exe": "powershell.exe -ExecutionPolicy Bypass -File scripts/windows/smoke-exe.ps1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0"
  }
}
