{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capability",
  "remote": {
    "urls": [
      "http://127.0.0.1:*",
      "http://localhost:*"
    ]
  },
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:app:allow-version",
    "core:window:allow-minimize"
  ]
}
