{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "moduleResolution": "Bundler",
    "target": "ES2022"
  },
  "include": [
    "apps/windows/backend/src/**/*.ts",
    "apps/windows/ui/src/**/*.{js,jsx,ts,tsx}"
  ],
  "exclude": [
    "node_modules",
    "apps/android",
    "apps/windows/**/dist",
    "apps/windows/**/build"
  ]
}
